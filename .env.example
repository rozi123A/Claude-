# ===== DATABASE =====
# PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST/YOUR_DB?sslmode=require

# ===== TELEGRAM =====
# Telegram Bot Token from BotFather
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID for receiving notifications
ADMIN_TELEGRAM_ID=123456789

# Admin Chat ID
ADMIN_CHAT_ID=123456789

# Admin Secret for dashboard access
ADMIN_SECRET=your_secure_random_secret_here

# ===== SECURITY =====
ADMIN_KEY=your_secure_admin_key_here
JWT_SECRET=your_jwt_secret_here

# ===== FRONTEND =====
FRONTEND_URL=https://your-app.onrender.com
WEBAPP_URL=https://your-app.onrender.com

# ===== ENVIRONMENT =====
NODE_ENV=production

# ===== SETTINGS =====
AD_REWARD=10
MIN_WITHDRAW=10000
STARS_RATE=1000
AD_COOLDOWN=30
