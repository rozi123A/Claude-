# ===== DATABASE =====
  # PostgreSQL connection string (Neon)
  # Format: postgresql://user:password@host/database?sslmode=require
  DATABASE_URL=postgresql://neondb_owner:npg_JxMhu7PD9jQT@ep-raspy-night-aqjxa9yl-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

  # ===== TELEGRAM =====
  # Telegram Bot Token from BotFather
  # Get it from: https://t.me/botfather
  BOT_TOKEN=your_bot_token_here

  # Admin Chat ID for receiving notifications
  # Get your ID: https://t.me/userinfobot
  ADMIN_CHAT_ID=123456789

  # ===== ADSGRAM =====
  # Adsgram Block ID for ad integration
  # Get it from: https://adsgram.io
  ADSGRAM_BLOCK_ID=your_adsgram_block_id

  # ===== SECURITY =====
  # Secure admin key for admin operations
  # Generate a random string: openssl rand -hex 32
  ADMIN_KEY=your_secure_admin_key_here

  # ===== FRONTEND =====
  # Frontend URL for CORS
  FRONTEND_URL=http://localhost:3000

  # Web App URL for Telegram Mini App
  # This is the public URL where your frontend is hosted
  WEBAPP_URL=https://your-frontend.pages.dev

  # ===== ENVIRONMENT =====
  # Development or production
  NODE_ENV=development

  # ===== DEVELOPMENT ONLY =====
  # Development user ID for testing without Telegram
  # Leave empty for production
  DEV_USER_ID=123456789

  # ===== SETTINGS =====
  # Ad reward in points
  AD_REWARD=100

  # Minimum withdrawal amount in points
  MIN_WITHDRAW=10000

  # Conversion rate: points to stars
  # 1000 points = 1 star
  STARS_RATE=1000

  # Cooldown between ads in seconds
  AD_COOLDOWN=30

  # ===== OPTIONAL =====
  # For future integrations
  # STRIPE_API_KEY=your_stripe_key
  # OPENAI_API_KEY=your_openai_key
  