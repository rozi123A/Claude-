# ===== DATABASE =====
# PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST/YOUR_DB?sslmode=require

# ===== TELEGRAM =====
# Telegram Bot Token from BotFather
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID for receiving notifications
ADMIN_TELEGRAM_ID=123456789

# Admin Chat ID
ADMIN_CHAT_ID=123456789

# Admin Secret for dashboard access
ADMIN_SECRET=your_secure_random_secret_here

# ===== SECURITY =====
JWT_SECRET=your_jwt_secret_here

# ===== FRONTEND =====
FRONTEND_URL=https://your-app.onrender.com
WEBAPP_URL=https://your-app.onrender.com

# ===== ENVIRONMENT =====
NODE_ENV=production

# ===== SETTINGS =====
AD_REWARD=10
MIN_WITHDRAW=10000
STARS_RATE=1000
AD_COOLDOWN=30

# ===== ADSGRAM (إعلانات Telegram) =====
# !! مهم جداً !! بدون هذا لن تظهر الإعلانات
# 1. اذهب إلى https://adsgram.ai → سجّل كـ Publisher
# 2. أنشئ Block جديد → نوع: Rewarded / Interstitial
# 3. انسخ الـ Block ID الرقمي (مثال: 34660) والصقه هنا

# Server-side (يستخدمه الباك إند للـ fallback / admin checks)
ADSGRAM_BLOCK=34660
ADSGRAM_BLOCK_ID=34660

# Client-side (يستخدمه الفرونت لتحميل SDK وعرض الإعلان)
# Vite يصدّر فقط المتغيرات اللي تبدا بـ VITE_ للـ client
VITE_ADSGRAM_BLOCK_ID=34660

# رابط لوحة AdsGram (للأدمن Dashboard)
ADSGRAM_DASHBOARD_URL=https://partner.adsgram.ai

# ===== FAUCETPAY (Auto DGB Payouts) =====
FAUCETPAY_API_KEY=your_faucetpay_api_key_here
